<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APPID@</id>
  <launchable type="desktop-id">@APPID@.desktop</launchable>
  <name>@NAME@</name>
  <url type="homepage">https://github.com/forbidden-game/panmux</url>
  <url type="help">https://github.com/forbidden-game/panmux#readme</url>
  <url type="bugtracker">https://github.com/forbidden-game/panmux/issues</url>
  <url type="contact">https://github.com/forbidden-game/panmux#readme</url>
  <url type="contribute">https://github.com/forbidden-game/panmux/blob/main/CONTRIBUTING.md</url>
  <url type="translate">https://github.com/forbidden-game/panmux/blob/main/po/README_TRANSLATORS.md</url>
  <url type="vcs-browser">https://github.com/forbidden-game/panmux</url>
  <summary>Panmux is a Ghostty GTK fork for coding-agent terminal workflows on Linux and Wayland</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <content_rating type="oars-1.1" />
  <developer id="io.github.forbidden-game">
    <name>Xiezhao Pan</name>
  </developer>
  <description>
    <p>
      Panmux keeps Ghostty's terminal core and reworks the Linux GTK shell
      around it for coding-agent workflows. The project focuses on making
      long-running sessions easier to scan, switch, and coordinate with a
      workflow-oriented tab UI and lightweight control plane.
    </p>
  </description>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>
  <requires>
    <!--
      Mobile/tablet AND desktop supported

      Ref: https://docs.flathub.org/docs/for-app-authors/metainfo-guidelines#display-size
    -->
    <display_length compare="ge">360</display_length>
  </requires>
  <translation type="gettext">com.mitchellh.ghostty</translation>

  <!--
    TODO: Generate manifest location data.

    Ref: https://docs.flathub.org/docs/for-app-authors/metainfo-guidelines#manifest-location

  <custom>
    <value key="flathub::manifest">https://github.com/ghostty-org/ghostty/blob/<hash>/flatpak/com.mitchellh.ghostty.yml</value>
  </custom>
  -->

  <releases>
    <!-- TODO: Generate this automatically -->
    <release version="1.0.1" date="2024-12-31">
        <url type="details">https://github.com/forbidden-game/panmux/releases</url>
    </release>
  </releases>
</component>
